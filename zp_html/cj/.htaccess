# 采集器可见目录 zp_html/cj/（挂载于 http://zhaopin.es/cj/）；
# 私有逻辑在 app/cj/（web root 之外），Web 天然不可达。
# 本文件仅做目录保护（Apache 环境；Nginx 按 README 配置）。

Options -Indexes

# 透传 Authorization 头给 PHP（FastCGI/PHP-FPM 下 Basic Auth 才能拿到用户名密码，
# 否则会“输对密码仍反复弹框”）。SetEnvIf 兼容性最好；另备 CGIPassAuth（Apache 2.4.13+）。
SetEnvIf Authorization "(.*)" HTTP_AUTHORIZATION=$1
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
</IfModule>

# 禁止访问隐藏文件
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# 只允许指定入口执行 PHP，其余一律拒绝
<FilesMatch "\.php$">
    Require all denied
</FilesMatch>
<FilesMatch "^(index|review|dashboard)\.php$">
    Require all granted
</FilesMatch>
